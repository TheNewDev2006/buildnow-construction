{
  "cleanUrls": true,
  "rewrites": [
    { "source": "/:path*.php", "destination": "/:path*.html" },
    { "source": "/index.php", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
